
# Используем официальный образ n8n как основу
FROM n8nio/n8n

# Устанавливаем рабочую директорию
WORKDIR /app

# Копируем файлы из репозитория в контейнер
COPY . .

# Устанавливаем зависимости (если есть)
RUN npm install

# Открываем порт для работы n8n (по умолчанию 5678)
EXPOSE 5678

# Команда для запуска n8n
CMD ["n8n"]
